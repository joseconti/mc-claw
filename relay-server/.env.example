# McClaw Relay Server Configuration

# Port to listen on
PORT=8443

# Maximum concurrent rooms (1 room = 1 McClaw Mac + its mobile devices)
MAX_ROOMS=1000

# JWT secret shared with api.joseconti.com for McClaw Cloud auth.
# When set, clients must send a valid JWT in Authorization: Bearer <jwt>
# Leave empty for open/self-hosted mode (no auth required).
RELAY_JWT_SECRET=
